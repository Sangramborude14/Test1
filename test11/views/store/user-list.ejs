<%- include('../partials/head') %>

<body>
    <header>
        <%- include('../partials/nav') %>
        <h1>Registered User Names</h1>
        <% if (locals.errorMessage) { %>
            <h2 style="color: #e74c3c; background: #fadbd8; padding: 10px; border-radius: 5px; font-size: 1rem; margin-top: 10px; text-align: center;">
                <%= errorMessage %>
            </h2>
        <% } %>
    </header>
    <main>
        <ul class="user-list">
            <% registeredHomes.forEach(home => { %>
                <li class="user-list-item">
                    <div class="user-list-info">
                        <span class="user-name-tag"><%= home.name %></span>
                    </div>
                    <div class="user-actions">
                        <a href="/host/edit" class="btn btn-primary">EDIT</a>
                        <a href="/host/delete?id=<%= home._id %>" class="btn btn-danger">DELETE</a>
                    </div>
                </li>
            <% }) %>
        </ul>
    </main>
</body>

</html>