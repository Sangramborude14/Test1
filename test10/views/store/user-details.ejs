<%- include('../partials/head') %>

<body>
    <header>
        <%- include('../partials/nav') %>
        <h1>Registered Profiles</h1>
    </header>
    <main>
        <div class="card-container">
            <% registeredHomes.forEach( home => { %>
                <div class="cards">
                    <h2>User Profile</h2>
                    <div class="user-info-item">
                        <strong>Name:</strong>
                        <span><%= home.name %></span>
                    </div>
                    <div class="user-info-item">
                        <strong>Age:</strong>
                        <span><%= home.age %></span>
                    </div>
                    <div class="user-info-item">
                        <strong>Email:</strong>
                        <span><%= home.email %></span>
                    </div>
                    <div class="user-info-item">
                        <strong>Mobile:</strong>
                        <span><%= home.mobile %></span>
                    </div>
                    <div class="user-info-item">
                        <strong>Gender:</strong>
                        <span><%= home.gender %></span>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>
</body>

</html>