<%- include('../partials/head') %>

    <body>
        <header>
            <%- include('../partials/nav') %>
                <h1>User Details </h1>
        </header>
        <main style="max-width: 900px;">
            <h1 style="margin-bottom: 30px;">Details of Registered Users</h1>
            <div class="card-container">
                <% registeredHomes.forEach( home=> { %>
                    <div class="cards">
                        <h2>User Profile</h2>
                        <strong>Name:</strong>
                        <%= home.name %><br>
                            <strong>Age:</strong>
                            <%= home.age %><br>
                                <strong>Email:</strong>
                                <%= home.email %><br>
                                    <strong>Mobile:</strong>
                                    <%= home.mobile %><br>
                                        <strong>Gender:</strong>
                                        <%= home.gender %><br>
                    </div>
                    <% }) %>
            </div>
        </main>
    </body>

    </html>