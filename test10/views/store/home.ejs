<%- include('../partials/head') %>

<body>
    <header>
        <%- include('../partials/nav') %>
        <h1>Welcome to NORD</h1>
        <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: -1rem;">Management System & User Directory</p>
    </header>
    
    <main>
        <div style="margin-bottom: 3rem;">
            <a href="/host/contact-us" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem;">Register New User</a>
        </div>

        <h2 style="margin-bottom: 2rem;">Overview of Registered Users</h2>
        <div class="card-container">
            <% registeredHomes.forEach(home => { %>
                <div class="cards">
                    <h2><%= home.name %></h2>
                    <div class="user-info-item">
                        <strong>Email:</strong>
                        <span><%= home.email %></span>
                    </div>
                    <div class="user-info-item">
                        <strong>Gender:</strong>
                        <span><%= home.gender %></span>
                    </div>
                    <div style="margin-top: 1.5rem;">
                        <a href="/user-details" class="btn btn-outline" style="width: 100%;">View Full Profile</a>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>

</body>

</html>